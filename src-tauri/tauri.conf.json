{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Life Hotel Automation Hub",
  "version": "0.1.0",
  "identifier": "com.lifehotel.automationhub",
  "build": {
    "beforeDevCommand": "npm run dev:vite",
    "devUrl": "http://127.0.0.1:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Life Hotel Automation Hub",
        "width": 1180,
        "height": 780,
        "minWidth": 960,
        "minHeight": 680
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "publisher": "Life Hotel"
  }
}
